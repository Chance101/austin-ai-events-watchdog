# Supabase read access to the austinai.events database
# Use the anon key (read-only), not the service role key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Optional: service role key if you want the watchdog to write its findings
# back to the coverage_audits table. If unset, the watchdog logs to stdout only.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Threshold for the liveness alert: if fewer than this many events exist in
# the next 14 days, emit a warning to the workflow log (and optionally email)
ALERT_THRESHOLD_EVENTS=5

# Optional: email address to receive alerts when thresholds trip
# ALERT_EMAIL=you@example.com

# Kill switch. Set to 1 to disable the watchdog without removing the workflow.
# WATCHDOG_DISABLED=0
